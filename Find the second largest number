#include <iostream>
using namespace std;

int main() {
    int a[5];

    for(int i = 0; i < 5; i++)
        cin >> a[i];

    int largest = a[0];
    int second = a[0];

    for(int i = 1; i < 5; i++) {
        if(a[i] > largest) {
            second = largest;
            largest = a[i];
        } else if(a[i] > second && a[i] != largest) {
            second = a[i];
        }
    }

    cout << "Second Largest = " << second;

    return 0;
}
