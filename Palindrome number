#include <iostream>
using namespace std;

int main()
{
    int n, temp, rem, rev = 0;

    cout << "Enter a number: ";
    cin >> n;

    temp = n;

    while (n != 0)
    {
        rem = n % 10;
        rev = rev * 10 + rem;
        n = n / 10;
    }

    if (temp == rev)
        cout << "Palindrome";
    else
        cout << "Not a Palindrome";

    return 0;
}
